class Solution {
    
    public int maxProfit(int[] prices) {
        int min=prices[0];
        int profite=0;
        for(int i=0; i<prices.length; i++){
            int currProfite = prices[i]-min;
           min = Math.min(min, prices[i]);
            profite= Math.max(profite, currProfite);
       
        }
        return profite;
    }
}
